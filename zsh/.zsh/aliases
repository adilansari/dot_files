# master
alias zshconf="vi ~/.zshrc"
alias zshreload="source ~/.zshrc"
aliases() {
  local files=(~/.zsh/aliases ~/.zsh/tigris_aliases)
  local search="$*"
  local existing=()
  for f in "${files[@]}"; do
    [[ -f "$f" ]] && existing+=("$f")
  done
  [[ ${#existing[@]} -eq 0 ]] && return

  awk -v search="${search:-.}" '
    BEGIN {
      search = tolower(search)
      n = split(search, keywords, " ")
    }
    /^alias / {
      check_and_store($0)
    }
    /^[a-zA-Z_][a-zA-Z0-9_]* *\(\)/ {
      in_fn = 1; body = ""
    }
    in_fn {
      body = body $0 "\n"
      if (/^\}/) {
        check_and_store(body)
        in_fn = 0
      }
    }
    function check_and_store(block) {
      lower = tolower(block)
      hits = 0
      for (i = 1; i <= n; i++) {
        if (lower ~ keywords[i]) hits++
      }
      if (hits > 0) {
        blocks[++count] = block
        scores[count] = hits
      }
    }
    END {
      for (i = 2; i <= count; i++) {
        kb = blocks[i]; ks = scores[i]; j = i - 1
        while (j > 0 && scores[j] > ks) {
          blocks[j+1] = blocks[j]; scores[j+1] = scores[j]; j--
        }
        blocks[j+1] = kb; scores[j+1] = ks
      }
      for (i = 1; i <= count; i++) {
        printf "%s\n", blocks[i]
      }
    }
  ' "${existing[@]}" | \
  if [[ -n "$search" ]]; then
    grep --color=always -i -E "$(echo "$search" | tr ' ' '|')|$"
  else
    command cat
  fi
}

