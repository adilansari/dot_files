# create worktree + branch
# usage: gwb provider-invoicing
gwb() {
  local branch=$1
  local repo_name=$(basename $(git rev-parse --show-toplevel))
  local parent=$(dirname $(git rev-parse --show-toplevel))
  local worktree_dir="$parent/${repo_name}-${branch}"
  git worktree add -b "$branch" "$worktree_dir" main
  echo "✓ Created: $worktree_dir"
}

# remove worktree after gh pr merge -sd
# usage: gwrm provider-invoicing
gwrm() {
  local branch=$1
  local repo_name=$(basename $(git rev-parse --show-toplevel))
  local parent=$(dirname $(git rev-parse --show-toplevel))
  local worktree_dir="$parent/${repo_name}-${branch}"
  git worktree remove "$worktree_dir"
  echo "✓ Removed worktree: $branch"
}

# checkout a PR into its own worktree for review
# usage: gwpr 123
gwpr() {
  local pr=$1
  local repo_name=$(basename $(git rev-parse --show-toplevel))
  local parent=$(dirname $(git rev-parse --show-toplevel))
  local worktree_dir="$parent/${repo_name}-pr-${pr}"
  gh pr checkout "$pr" --worktree "$worktree_dir" 2>/dev/null || {
    local branch=$(gh pr view "$pr" --json headRefName -q '.headRefName')
    git worktree add "$worktree_dir" "$branch" 2>/dev/null || \
    git worktree add -b "pr-${pr}-review" "$worktree_dir" "origin/${branch}"
  }
  echo "✓ PR #$pr checked out at: $worktree_dir"
}

